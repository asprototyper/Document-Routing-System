# Copy this file to .env.local (root) and/or src/.env.local and fill in real values.

# ─── Client (Vite) ─────────────────────────────────────────────
# These are bundled into the browser. The anon key here is inert
# on its own — RLS only allows authenticated sessions (see
# supabase/schema.sql). Access is gated via /api/login.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# ─── Server (Vercel serverless / `vercel dev`) ─────────────────
# Same Supabase project values, without the VITE_ prefix, so
# api/*.js functions can read them via process.env.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Shared app account the server signs in as after a valid PIN.
# Create this user in Supabase → Authentication → Users.
# Use a long, random password — only the server ever sees it.
SUPABASE_SHARED_EMAIL=tracker-service@example.com
SUPABASE_SHARED_PASSWORD=replace-with-long-random-password

# bcrypt hash of the shared PIN. Generate with:
#   npm run hash-pin 0000
# Then paste the PIN_HASH=... line this command prints.
PIN_HASH=$2b$12$replace-with-real-bcrypt-hash-from-hash-pin-script

# ─── SMTP (used by /api/send-email) ────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=Your Org <notifications@example.com>
